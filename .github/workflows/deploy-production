name: Deploy to Production on merge into main

on:
  push:
    branches:
      - main  # Only triggers on pushes to the main branch

jobs:
  build_and_deploy:
    runs-on: ubuntu-latest

    steps:
      # Checkout the code
      - name: Checkout code
        uses: actions/checkout@v4

      # Install dependencies and build the frontend
      - name: Install dependencies and build frontend
        run: npm ci && npm run build

      # Authenticate with Google Cloud (using service account from GOOGLE_APPLICATION_CREDENTIALS)
      - name: Authenticate with Google Cloud
        uses: google-github-actions/auth@v1
        with:
          credentials_json: ${{ secrets.GOOGLE_APPLICATION_CREDENTIALS }}  # Google Cloud service account key

      # Deploy frontend to Firebase Hosting (live)
      - name: Deploy frontend to Firebase Hosting (live)
        uses: FirebaseExtended/action-hosting-deploy@v0
        with:
          repoToken: ${{ secrets.GITHUB_TOKEN }}  # GitHub token to authenticate with Firebase Hosting
          firebaseServiceAccount: ${{ secrets.GOOGLE_APPLICATION_CREDENTIALS }}  # Use the same service account key for Firebase Hosting
          projectId: deckhubapp  # Firebase project ID
          channelId: live  # Deploy to the live (production) channel

      # Verify Google Cloud Authentication
      - name: Verify Google Cloud Authentication
        run: |
          gcloud config list project

      # Set up Google Cloud SDK for Cloud Run
      - name: Set up Google Cloud SDK
        uses: google-github-actions/setup-gcloud@v1
        with:
          project_id: ${{ secrets.GCP_PROJECT }}  # Google Cloud project ID

      # Authenticate Docker with GCR
      - name: Authenticate Docker with GCR
        run: gcloud auth configure-docker

      # Build Docker image for backend (correct path to the Dockerfile)
      - name: Build Docker image for backend
        run: |
          docker build -t gcr.io/${{ secrets.GCP_PROJECT }}/backend-cloud:${{ github.sha }} ./src/backend

      # Push Docker image to GCR
      - name: Push Docker image to GCR
        run: |
          docker push gcr.io/${{ secrets.GCP_PROJECT }}/backend-cloud:${{ github.sha }}

      # Deploy the backend to Google Cloud Run (production)
      - name: Deploy backend to Cloud Run
        run: |
          gcloud run deploy deckhub-backend \
            --image gcr.io/${{ secrets.GCP_PROJECT }}/backend-cloud:${{ github.sha }} \
            --platform managed \
            --region us-central1 \
            --allow-unauthenticated \
            --set-env-vars "OPENAI_API_KEY=${{ secrets.OPENAI_API_KEY }}" \
            --set-env-vars "LOCAL=False"
